{
  "$defs": {
    "EvidenceSnippet": {
      "additionalProperties": false,
      "description": "판정 또는 요약 근거로 사용된 snippet.",
      "properties": {
        "locator": {
          "description": "근거 위치 정보",
          "title": "Locator",
          "type": "string"
        },
        "snippet_text": {
          "description": "근거 본문",
          "title": "Snippet Text",
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거의 원문 URL",
          "title": "Source Url"
        },
        "supports_fields": {
          "description": "이 snippet이 뒷받침하는 필드 이름 목록",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Supports Fields",
          "type": "array"
        }
      },
      "required": [
        "locator",
        "snippet_text",
        "supports_fields"
      ],
      "title": "EvidenceSnippet",
      "type": "object"
    },
    "RelevanceDecision": {
      "description": "관련성 판단 결과.",
      "enum": [
        "relevant",
        "borderline",
        "not_relevant"
      ],
      "title": "RelevanceDecision",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "관련성 판정 결과와 근거.",
  "properties": {
    "decision_reason": {
      "description": "판정 사유 요약",
      "title": "Decision Reason",
      "type": "string"
    },
    "document_id": {
      "description": "대상 문헌 ID",
      "title": "Document Id",
      "type": "string"
    },
    "evidence_links_or_snippets": {
      "description": "관련성 근거",
      "items": {
        "$ref": "#/$defs/EvidenceSnippet"
      },
      "title": "Evidence Links Or Snippets",
      "type": "array"
    },
    "final_decision": {
      "$ref": "#/$defs/RelevanceDecision",
      "description": "최종 관련성 판정"
    },
    "llm_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "LLM 점수",
      "title": "Llm Score"
    },
    "matched_classifications": {
      "description": "매칭된 분류 코드",
      "items": {
        "type": "string"
      },
      "title": "Matched Classifications",
      "type": "array"
    },
    "matched_terms": {
      "description": "매칭된 용어",
      "items": {
        "type": "string"
      },
      "title": "Matched Terms",
      "type": "array"
    },
    "metadata_score": {
      "description": "메타데이터 점수",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Metadata Score",
      "type": "number"
    },
    "review_required": {
      "default": false,
      "description": "사람 검수 필요 여부",
      "title": "Review Required",
      "type": "boolean"
    },
    "rule_score": {
      "description": "규칙 기반 점수",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Rule Score",
      "type": "number"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "document_id",
    "rule_score",
    "metadata_score",
    "final_decision",
    "decision_reason"
  ],
  "title": "RelevanceAssessment",
  "type": "object"
}