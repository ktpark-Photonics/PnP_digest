{
  "$defs": {
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render",
        "release",
        "publish"
      ],
      "title": "StageName",
      "type": "string"
    },
    "VerificationReport": {
      "additionalProperties": false,
      "description": "문헌별 검증 결과 묶음.",
      "properties": {
        "document_id": {
          "description": "대상 문헌 ID",
          "title": "Document Id",
          "type": "string"
        },
        "existence_check": {
          "$ref": "#/$defs/VerificationResult",
          "description": "특허 실재 여부 확인 결과"
        },
        "overall_pass": {
          "description": "전체 검증 통과 여부",
          "title": "Overall Pass",
          "type": "boolean"
        },
        "provider_name": {
          "description": "사용한 특허 검증 provider 이름",
          "title": "Provider Name",
          "type": "string"
        },
        "results": {
          "description": "필드별 결과",
          "items": {
            "$ref": "#/$defs/VerificationResult"
          },
          "title": "Results",
          "type": "array"
        },
        "review_required": {
          "description": "사람 검수 필요 여부",
          "title": "Review Required",
          "type": "boolean"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "provider_name",
        "overall_pass",
        "review_required",
        "existence_check"
      ],
      "title": "VerificationReport",
      "type": "object"
    },
    "VerificationResult": {
      "additionalProperties": false,
      "description": "필드 단위 검증 결과.",
      "properties": {
        "checked_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검증 시각",
          "title": "Checked At"
        },
        "confidence": {
          "description": "검증 신뢰도",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거 출처",
          "title": "Evidence Source"
        },
        "evidence_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거 텍스트",
          "title": "Evidence Text"
        },
        "expected_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "내부 기록값",
          "title": "Expected Value"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 메모",
          "title": "Notes"
        },
        "observed_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "외부 근거값",
          "title": "Observed Value"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/VerificationStatus",
          "description": "검증 상태"
        },
        "verification_field": {
          "description": "검증 대상 필드",
          "title": "Verification Field",
          "type": "string"
        }
      },
      "required": [
        "verification_field",
        "status",
        "confidence"
      ],
      "title": "VerificationResult",
      "type": "object"
    },
    "VerificationStatus": {
      "description": "필드 단위 검증 상태.",
      "enum": [
        "matched",
        "partially_matched",
        "mismatched",
        "missing",
        "not_checked",
        "manual_review_required"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "verify 단계 산출물.",
  "properties": {
    "reports": {
      "description": "특허 검증 결과 목록",
      "items": {
        "$ref": "#/$defs/VerificationReport"
      },
      "title": "Reports",
      "type": "array"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run"
  ],
  "title": "VerificationArtifact",
  "type": "object"
}