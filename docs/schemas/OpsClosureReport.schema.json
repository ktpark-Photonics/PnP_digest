{
  "$defs": {
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "ReviewChecklistItem": {
      "additionalProperties": false,
      "description": "검수 체크리스트 항목.",
      "properties": {
        "item_id": {
          "description": "체크 항목 식별자",
          "title": "Item Id",
          "type": "string"
        },
        "prompt": {
          "description": "검토 질문",
          "title": "Prompt",
          "type": "string"
        },
        "required": {
          "default": true,
          "description": "필수 여부",
          "title": "Required",
          "type": "boolean"
        },
        "response": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 결과 또는 메모",
          "title": "Response"
        }
      },
      "required": [
        "item_id",
        "prompt"
      ],
      "title": "ReviewChecklistItem",
      "type": "object"
    },
    "ReviewStage": {
      "description": "사람 검수가 개입하는 단계.",
      "enum": [
        "relevance",
        "verification",
        "summary",
        "figure",
        "final_release",
        "publish"
      ],
      "title": "ReviewStage",
      "type": "string"
    },
    "ReviewTask": {
      "additionalProperties": false,
      "description": "사람 검수 워크플로 엔터티.",
      "properties": {
        "assignee": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "담당자",
          "title": "Assignee"
        },
        "checklist": {
          "description": "검수 체크리스트",
          "items": {
            "$ref": "#/$defs/ReviewChecklistItem"
          },
          "title": "Checklist",
          "type": "array"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 메모",
          "title": "Notes"
        },
        "review_stage": {
          "$ref": "#/$defs/ReviewStage",
          "description": "검수 단계"
        },
        "review_task_id": {
          "description": "검수 작업 식별자",
          "title": "Review Task Id",
          "type": "string"
        },
        "reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 완료 시각",
          "title": "Reviewed At"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ReviewTaskStatus",
          "description": "검수 상태"
        },
        "target_id": {
          "description": "검토 대상 식별자",
          "title": "Target Id",
          "type": "string"
        },
        "target_type": {
          "description": "검토 대상 유형",
          "title": "Target Type",
          "type": "string"
        }
      },
      "required": [
        "review_task_id",
        "target_type",
        "target_id",
        "review_stage",
        "status"
      ],
      "title": "ReviewTask",
      "type": "object"
    },
    "ReviewTaskStatus": {
      "description": "검수 작업 상태.",
      "enum": [
        "open",
        "in_review",
        "approved",
        "rejected"
      ],
      "title": "ReviewTaskStatus",
      "type": "string"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render",
        "release",
        "publish",
        "retry",
        "handoff",
        "followup",
        "escalation",
        "closure"
      ],
      "title": "StageName",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "escalation resolution 이후 최종 운영 상태를 정리한 closure report.",
  "properties": {
    "blocked_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "원본 escalation 단계 차단 사유",
      "title": "Blocked Reason"
    },
    "closed_task_count": {
      "default": 0,
      "description": "종결된 task 수",
      "title": "Closed Task Count",
      "type": "integer"
    },
    "closed_tasks": {
      "description": "종결된 task 목록",
      "items": {
        "$ref": "#/$defs/ReviewTask"
      },
      "title": "Closed Tasks",
      "type": "array"
    },
    "closure_team": {
      "description": "종료 보고를 정리한 팀",
      "title": "Closure Team",
      "type": "string"
    },
    "generated_at": {
      "description": "closure report 생성 시각",
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "remaining_task_count": {
      "default": 0,
      "description": "아직 남아 있는 task 수",
      "title": "Remaining Task Count",
      "type": "integer"
    },
    "remaining_tasks": {
      "description": "추가 대응이 필요한 task 목록",
      "items": {
        "$ref": "#/$defs/ReviewTask"
      },
      "title": "Remaining Tasks",
      "type": "array"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "run_id": {
      "description": "연결된 run ID",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    },
    "source_escalation_resolution_path": {
      "description": "입력 escalation resolution 경로",
      "title": "Source Escalation Resolution Path",
      "type": "string"
    }
  },
  "required": [
    "run",
    "run_id",
    "source_escalation_resolution_path",
    "closure_team",
    "generated_at"
  ],
  "title": "OpsClosureReport",
  "type": "object"
}