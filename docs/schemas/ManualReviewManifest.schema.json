{
  "$defs": {
    "ManualReviewItem": {
      "additionalProperties": false,
      "description": "수동 검토 대상 요약 항목.",
      "properties": {
        "decision_reason": {
          "description": "검토 필요 사유",
          "title": "Decision Reason",
          "type": "string"
        },
        "document_id": {
          "description": "검토 대상 문헌 ID",
          "title": "Document Id",
          "type": "string"
        },
        "evidence_locators": {
          "description": "검토자가 볼 근거 locator 목록",
          "items": {
            "type": "string"
          },
          "title": "Evidence Locators",
          "type": "array"
        },
        "final_decision": {
          "$ref": "#/$defs/RelevanceDecision",
          "description": "관련성 판정"
        },
        "rule_score": {
          "description": "규칙 점수",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Rule Score",
          "type": "number"
        }
      },
      "required": [
        "document_id",
        "final_decision",
        "rule_score",
        "decision_reason"
      ],
      "title": "ManualReviewItem",
      "type": "object"
    },
    "RelevanceDecision": {
      "description": "관련성 판단 결과.",
      "enum": [
        "relevant",
        "borderline",
        "not_relevant"
      ],
      "title": "RelevanceDecision",
      "type": "string"
    },
    "ReviewStage": {
      "description": "사람 검수가 개입하는 단계.",
      "enum": [
        "relevance",
        "verification",
        "summary",
        "figure",
        "final_release"
      ],
      "title": "ReviewStage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "수동 검토가 필요한 문헌 목록.",
  "properties": {
    "items": {
      "description": "수동 검토 항목",
      "items": {
        "$ref": "#/$defs/ManualReviewItem"
      },
      "title": "Items",
      "type": "array"
    },
    "review_stage": {
      "$ref": "#/$defs/ReviewStage",
      "default": "relevance",
      "description": "검토 단계"
    },
    "run_id": {
      "description": "연결된 run ID",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run_id"
  ],
  "title": "ManualReviewManifest",
  "type": "object"
}