{
  "$defs": {
    "DocumentRecord": {
      "additionalProperties": false,
      "description": "정규화된 공통 문헌 엔터티.",
      "properties": {
        "abstract_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "정규화된 초록 또는 요약",
          "title": "Abstract Text"
        },
        "canonical_title": {
          "description": "정규화된 제목",
          "title": "Canonical Title",
          "type": "string"
        },
        "canonical_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "대표 URL",
          "title": "Canonical Url"
        },
        "dedup_candidate_keys": {
          "description": "중복 후보 비교를 위한 canonical key 목록",
          "items": {
            "type": "string"
          },
          "title": "Dedup Candidate Keys",
          "type": "array"
        },
        "document_id": {
          "description": "정규화된 문헌 식별자",
          "title": "Document Id",
          "type": "string"
        },
        "document_type": {
          "$ref": "#/$defs/DocumentType",
          "description": "문헌 유형"
        },
        "fingerprint": {
          "description": "중복 판단에 사용하는 fingerprint",
          "title": "Fingerprint",
          "type": "string"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "문헌 언어",
          "title": "Language"
        },
        "metadata": {
          "description": "문헌 유형별 세부 메타데이터",
          "discriminator": {
            "mapping": {
              "paper": "#/$defs/PaperMetadata",
              "patent": "#/$defs/PatentMetadata"
            },
            "propertyName": "metadata_type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PaperMetadata"
            },
            {
              "$ref": "#/$defs/PatentMetadata"
            }
          ],
          "title": "Metadata"
        },
        "publication_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "대표 공개일",
          "title": "Publication Date"
        },
        "review_status": {
          "$ref": "#/$defs/ReviewStatus",
          "default": "pending",
          "description": "현재 검수 상태"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "source_record_ids": {
          "description": "병합된 원시 레코드 목록",
          "items": {
            "type": "string"
          },
          "title": "Source Record Ids",
          "type": "array"
        }
      },
      "required": [
        "document_id",
        "document_type",
        "canonical_title",
        "fingerprint",
        "metadata"
      ],
      "title": "DocumentRecord",
      "type": "object"
    },
    "DocumentType": {
      "description": "문헌의 상위 유형.",
      "enum": [
        "paper",
        "patent"
      ],
      "title": "DocumentType",
      "type": "string"
    },
    "PaperMetadata": {
      "additionalProperties": false,
      "description": "논문 전용 메타데이터.",
      "properties": {
        "authors": {
          "description": "저자 목록",
          "items": {
            "type": "string"
          },
          "title": "Authors",
          "type": "array"
        },
        "doi": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "DOI",
          "title": "Doi"
        },
        "license": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "라이선스 정보",
          "title": "License"
        },
        "metadata_type": {
          "const": "paper",
          "default": "paper",
          "title": "Metadata Type",
          "type": "string"
        },
        "pdf_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "PDF URL",
          "title": "Pdf Url"
        },
        "publication_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "논문 유형",
          "title": "Publication Type"
        },
        "publisher": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "출판사",
          "title": "Publisher"
        },
        "venue": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "게재 학회 또는 저널",
          "title": "Venue"
        }
      },
      "title": "PaperMetadata",
      "type": "object"
    },
    "PatentMetadata": {
      "additionalProperties": false,
      "description": "특허 전용 메타데이터.",
      "properties": {
        "applicants": {
          "description": "출원인 목록",
          "items": {
            "type": "string"
          },
          "title": "Applicants",
          "type": "array"
        },
        "application_number": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "출원번호",
          "title": "Application Number"
        },
        "assignees": {
          "description": "권리자 목록",
          "items": {
            "type": "string"
          },
          "title": "Assignees",
          "type": "array"
        },
        "cpc_codes": {
          "description": "CPC 분류 코드",
          "items": {
            "type": "string"
          },
          "title": "Cpc Codes",
          "type": "array"
        },
        "family_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "패밀리 식별자",
          "title": "Family Id"
        },
        "filing_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "출원일",
          "title": "Filing Date"
        },
        "grant_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "등록일",
          "title": "Grant Date"
        },
        "inventors": {
          "description": "발명자 목록",
          "items": {
            "type": "string"
          },
          "title": "Inventors",
          "type": "array"
        },
        "ipc_codes": {
          "description": "IPC 분류 코드",
          "items": {
            "type": "string"
          },
          "title": "Ipc Codes",
          "type": "array"
        },
        "jurisdiction": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "관할 국가 또는 기관",
          "title": "Jurisdiction"
        },
        "metadata_type": {
          "const": "patent",
          "default": "patent",
          "title": "Metadata Type",
          "type": "string"
        },
        "patent_number": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "공개 또는 등록 특허번호",
          "title": "Patent Number"
        },
        "publication_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "공개일",
          "title": "Publication Date"
        }
      },
      "title": "PatentMetadata",
      "type": "object"
    },
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "ReviewStatus": {
      "description": "문헌 또는 자산의 검수 상태.",
      "enum": [
        "pending",
        "manual_review_required",
        "approved",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render"
      ],
      "title": "StageName",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "normalize 단계 산출물.",
  "properties": {
    "documents": {
      "description": "정규화된 문헌 목록",
      "items": {
        "$ref": "#/$defs/DocumentRecord"
      },
      "title": "Documents",
      "type": "array"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run"
  ],
  "title": "NormalizedArtifact",
  "type": "object"
}