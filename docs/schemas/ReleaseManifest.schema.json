{
  "$defs": {
    "ApprovalStatus": {
      "description": "배포 산출물 승인 상태.",
      "enum": [
        "draft",
        "pending_review",
        "approved",
        "rejected"
      ],
      "title": "ApprovalStatus",
      "type": "string"
    },
    "OutputBundle": {
      "additionalProperties": false,
      "description": "배포용 문서 산출물 메타데이터.",
      "properties": {
        "approval_status": {
          "$ref": "#/$defs/ApprovalStatus",
          "description": "배포 승인 상태"
        },
        "bundle_id": {
          "description": "산출물 묶음 ID",
          "title": "Bundle Id",
          "type": "string"
        },
        "included_document_ids": {
          "description": "포함된 문헌 ID",
          "items": {
            "type": "string"
          },
          "title": "Included Document Ids",
          "type": "array"
        },
        "output_path": {
          "description": "산출물 경로",
          "title": "Output Path",
          "type": "string"
        },
        "output_type": {
          "$ref": "#/$defs/OutputType",
          "description": "산출물 형식"
        },
        "run_id": {
          "description": "연결된 run ID",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "template_version": {
          "description": "템플릿 버전",
          "title": "Template Version",
          "type": "string"
        }
      },
      "required": [
        "bundle_id",
        "run_id",
        "output_type",
        "template_version",
        "output_path",
        "approval_status"
      ],
      "title": "OutputBundle",
      "type": "object"
    },
    "OutputType": {
      "description": "최종 산출물 형식.",
      "enum": [
        "markdown",
        "docx",
        "pptx",
        "pdf"
      ],
      "title": "OutputType",
      "type": "string"
    },
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "ReviewStage": {
      "description": "사람 검수가 개입하는 단계.",
      "enum": [
        "relevance",
        "verification",
        "summary",
        "figure",
        "final_release",
        "publish"
      ],
      "title": "ReviewStage",
      "type": "string"
    },
    "ReviewStatus": {
      "description": "문헌 또는 자산의 검수 상태.",
      "enum": [
        "pending",
        "manual_review_required",
        "approved",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render",
        "release",
        "publish"
      ],
      "title": "StageName",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "release 단계 배포 manifest.",
  "properties": {
    "approved_bundle_ids": {
      "description": "현재 승인 상태인 bundle ID 목록",
      "items": {
        "type": "string"
      },
      "title": "Approved Bundle Ids",
      "type": "array"
    },
    "approved_output_paths": {
      "description": "즉시 배포 가능한 출력 경로 목록",
      "items": {
        "type": "string"
      },
      "title": "Approved Output Paths",
      "type": "array"
    },
    "bundles": {
      "description": "release 검토 대상 bundle 목록",
      "items": {
        "$ref": "#/$defs/OutputBundle"
      },
      "title": "Bundles",
      "type": "array"
    },
    "distribution_targets": {
      "description": "배포 대상 채널",
      "items": {
        "type": "string"
      },
      "title": "Distribution Targets",
      "type": "array"
    },
    "generated_at": {
      "description": "manifest 생성 시각",
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "published_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "실제 배포 확정 시각",
      "title": "Published At"
    },
    "release_notes": {
      "description": "배포 메모",
      "items": {
        "type": "string"
      },
      "title": "Release Notes",
      "type": "array"
    },
    "review_signoff": {
      "$ref": "#/$defs/ReviewStatus",
      "description": "최종 배포 검토 상태"
    },
    "review_stage": {
      "$ref": "#/$defs/ReviewStage",
      "default": "final_release",
      "description": "최종 배포 검토 단계"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    },
    "source_render_artifact_path": {
      "description": "입력 render artifact 경로",
      "title": "Source Render Artifact Path",
      "type": "string"
    }
  },
  "required": [
    "run",
    "source_render_artifact_path",
    "review_signoff",
    "generated_at"
  ],
  "title": "ReleaseManifest",
  "type": "object"
}