{
  "$defs": {
    "VerificationResult": {
      "additionalProperties": false,
      "description": "필드 단위 검증 결과.",
      "properties": {
        "checked_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검증 시각",
          "title": "Checked At"
        },
        "confidence": {
          "description": "검증 신뢰도",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거 출처",
          "title": "Evidence Source"
        },
        "evidence_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거 텍스트",
          "title": "Evidence Text"
        },
        "expected_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "내부 기록값",
          "title": "Expected Value"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 메모",
          "title": "Notes"
        },
        "observed_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "외부 근거값",
          "title": "Observed Value"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/VerificationStatus",
          "description": "검증 상태"
        },
        "verification_field": {
          "description": "검증 대상 필드",
          "title": "Verification Field",
          "type": "string"
        }
      },
      "required": [
        "verification_field",
        "status",
        "confidence"
      ],
      "title": "VerificationResult",
      "type": "object"
    },
    "VerificationStatus": {
      "description": "필드 단위 검증 상태.",
      "enum": [
        "matched",
        "partially_matched",
        "mismatched",
        "missing",
        "not_checked",
        "manual_review_required"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "문헌별 검증 결과 묶음.",
  "properties": {
    "document_id": {
      "description": "대상 문헌 ID",
      "title": "Document Id",
      "type": "string"
    },
    "existence_check": {
      "$ref": "#/$defs/VerificationResult",
      "description": "특허 실재 여부 확인 결과"
    },
    "overall_pass": {
      "description": "전체 검증 통과 여부",
      "title": "Overall Pass",
      "type": "boolean"
    },
    "provider_name": {
      "description": "사용한 특허 검증 provider 이름",
      "title": "Provider Name",
      "type": "string"
    },
    "results": {
      "description": "필드별 결과",
      "items": {
        "$ref": "#/$defs/VerificationResult"
      },
      "title": "Results",
      "type": "array"
    },
    "review_required": {
      "description": "사람 검수 필요 여부",
      "title": "Review Required",
      "type": "boolean"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "document_id",
    "provider_name",
    "overall_pass",
    "review_required",
    "existence_check"
  ],
  "title": "VerificationReport",
  "type": "object"
}