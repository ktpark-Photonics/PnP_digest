{
  "$defs": {
    "OutputType": {
      "description": "최종 산출물 형식.",
      "enum": [
        "markdown",
        "docx",
        "pptx",
        "pdf"
      ],
      "title": "OutputType",
      "type": "string"
    },
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "PublishRecord": {
      "additionalProperties": false,
      "description": "채널별 publish stub 결과.",
      "properties": {
        "bundle_id": {
          "description": "배포 대상 bundle ID",
          "title": "Bundle Id",
          "type": "string"
        },
        "distribution_target": {
          "description": "배포 대상 채널",
          "title": "Distribution Target",
          "type": "string"
        },
        "external_reference": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "외부 시스템 참조값",
          "title": "External Reference"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "stub 메모",
          "title": "Notes"
        },
        "output_path": {
          "description": "산출물 경로",
          "title": "Output Path",
          "type": "string"
        },
        "output_type": {
          "$ref": "#/$defs/OutputType",
          "description": "산출물 형식"
        },
        "published_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "publish 처리 시각",
          "title": "Published At"
        },
        "status": {
          "$ref": "#/$defs/PublishStatus",
          "description": "publish 결과 상태"
        }
      },
      "required": [
        "bundle_id",
        "output_type",
        "output_path",
        "distribution_target",
        "status"
      ],
      "title": "PublishRecord",
      "type": "object"
    },
    "PublishStatus": {
      "description": "publish stub 실행 상태.",
      "enum": [
        "simulated",
        "published",
        "failed"
      ],
      "title": "PublishStatus",
      "type": "string"
    },
    "ReviewStatus": {
      "description": "문헌 또는 자산의 검수 상태.",
      "enum": [
        "pending",
        "manual_review_required",
        "approved",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render",
        "release",
        "publish",
        "retry",
        "handoff",
        "followup",
        "escalation",
        "closure"
      ],
      "title": "StageName",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "publish 단계 산출물.",
  "properties": {
    "blocked_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "publish가 차단된 사유",
      "title": "Blocked Reason"
    },
    "distribution_targets": {
      "description": "publish 대상 채널",
      "items": {
        "type": "string"
      },
      "title": "Distribution Targets",
      "type": "array"
    },
    "publish_records": {
      "description": "채널별 publish 결과 목록",
      "items": {
        "$ref": "#/$defs/PublishRecord"
      },
      "title": "Publish Records",
      "type": "array"
    },
    "review_signoff": {
      "$ref": "#/$defs/ReviewStatus",
      "description": "최종 배포 검토 승인 상태"
    },
    "reviewer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "최종 검토자 이름 또는 식별자",
      "title": "Reviewer"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    },
    "simulation_mode": {
      "default": true,
      "description": "실제 외부 배포 없이 stub만 생성했는지 여부",
      "title": "Simulation Mode",
      "type": "boolean"
    },
    "source_release_review_resolution_path": {
      "description": "입력 release review resolution 경로",
      "title": "Source Release Review Resolution Path",
      "type": "string"
    }
  },
  "required": [
    "run",
    "source_release_review_resolution_path",
    "review_signoff"
  ],
  "title": "PublishArtifact",
  "type": "object"
}