{
  "$defs": {
    "ReviewStage": {
      "description": "사람 검수가 개입하는 단계.",
      "enum": [
        "relevance",
        "verification",
        "summary",
        "figure",
        "final_release"
      ],
      "title": "ReviewStage",
      "type": "string"
    },
    "VerificationReviewItem": {
      "additionalProperties": false,
      "description": "verify 결과에서 수동 검토가 필요한 문헌 요약 항목.",
      "properties": {
        "document_id": {
          "description": "검토 대상 문헌 ID",
          "title": "Document Id",
          "type": "string"
        },
        "existence_status": {
          "$ref": "#/$defs/VerificationStatus",
          "description": "존재 확인 상태"
        },
        "flagged_fields": {
          "description": "주의가 필요한 필드 목록",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Flagged Fields",
          "type": "array"
        },
        "overall_pass": {
          "description": "전체 검증 통과 여부",
          "title": "Overall Pass",
          "type": "boolean"
        },
        "provider_name": {
          "description": "사용한 특허 검증 provider 이름",
          "title": "Provider Name",
          "type": "string"
        },
        "recommended_action": {
          "description": "권장 후속 조치",
          "title": "Recommended Action",
          "type": "string"
        },
        "review_reason": {
          "description": "검토 필요 사유 요약",
          "title": "Review Reason",
          "type": "string"
        },
        "source_artifact_path": {
          "description": "원본 verification artifact 경로",
          "title": "Source Artifact Path",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "provider_name",
        "review_reason",
        "existence_status",
        "flagged_fields",
        "overall_pass",
        "source_artifact_path",
        "recommended_action"
      ],
      "title": "VerificationReviewItem",
      "type": "object"
    },
    "VerificationStatus": {
      "description": "필드 단위 검증 상태.",
      "enum": [
        "matched",
        "partially_matched",
        "mismatched",
        "missing",
        "not_checked",
        "manual_review_required"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "verify 단계 수동 검토 입력 manifest.",
  "properties": {
    "items": {
      "description": "수동 검토 항목",
      "items": {
        "$ref": "#/$defs/VerificationReviewItem"
      },
      "title": "Items",
      "type": "array"
    },
    "review_stage": {
      "$ref": "#/$defs/ReviewStage",
      "default": "verification",
      "description": "검토 단계"
    },
    "run_id": {
      "description": "연결된 run ID",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run_id"
  ],
  "title": "VerificationReviewManifest",
  "type": "object"
}