{
  "$defs": {
    "ReviewStage": {
      "description": "사람 검수가 개입하는 단계.",
      "enum": [
        "relevance",
        "verification",
        "summary",
        "figure",
        "final_release",
        "publish"
      ],
      "title": "ReviewStage",
      "type": "string"
    },
    "ReviewStatus": {
      "description": "문헌 또는 자산의 검수 상태.",
      "enum": [
        "pending",
        "manual_review_required",
        "approved",
        "rejected"
      ],
      "title": "ReviewStatus",
      "type": "string"
    },
    "VerificationReviewResolutionItem": {
      "additionalProperties": false,
      "description": "수동 검토 후 확정된 verify 검토 결과.",
      "properties": {
        "document_id": {
          "description": "검토 대상 문헌 ID",
          "title": "Document Id",
          "type": "string"
        },
        "existence_status": {
          "$ref": "#/$defs/VerificationStatus",
          "description": "존재 확인 상태"
        },
        "flagged_fields": {
          "description": "검토가 필요했던 필드 목록",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Flagged Fields",
          "type": "array"
        },
        "provider_name": {
          "description": "사용한 특허 검증 provider 이름",
          "title": "Provider Name",
          "type": "string"
        },
        "resolved_fields": {
          "description": "검토 후 해소된 필드 목록",
          "items": {
            "type": "string"
          },
          "title": "Resolved Fields",
          "type": "array"
        },
        "review_notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토 메모",
          "title": "Review Notes"
        },
        "review_reason": {
          "description": "초기 검토 필요 사유",
          "title": "Review Reason",
          "type": "string"
        },
        "review_status": {
          "$ref": "#/$defs/ReviewStatus",
          "description": "사람 검토 후 최종 상태"
        },
        "reviewer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "검토자 이름 또는 식별자",
          "title": "Reviewer"
        },
        "source_artifact_path": {
          "description": "원본 verification artifact 경로",
          "title": "Source Artifact Path",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "provider_name",
        "existence_status",
        "flagged_fields",
        "review_status",
        "review_reason",
        "source_artifact_path"
      ],
      "title": "VerificationReviewResolutionItem",
      "type": "object"
    },
    "VerificationStatus": {
      "description": "필드 단위 검증 상태.",
      "enum": [
        "matched",
        "partially_matched",
        "mismatched",
        "missing",
        "not_checked",
        "manual_review_required"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "verification review CSV를 import한 결과 artifact.",
  "properties": {
    "imported_at": {
      "description": "CSV를 artifact로 반영한 시각",
      "format": "date-time",
      "title": "Imported At",
      "type": "string"
    },
    "imported_csv_path": {
      "description": "가져온 reviewer CSV 경로",
      "title": "Imported Csv Path",
      "type": "string"
    },
    "items": {
      "description": "수동 검토 반영 결과 목록",
      "items": {
        "$ref": "#/$defs/VerificationReviewResolutionItem"
      },
      "title": "Items",
      "type": "array"
    },
    "review_stage": {
      "$ref": "#/$defs/ReviewStage",
      "default": "verification",
      "description": "검토 단계"
    },
    "run_id": {
      "description": "연결된 run ID",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    },
    "source_manifest_path": {
      "description": "입력 verification review manifest 경로",
      "title": "Source Manifest Path",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "source_manifest_path",
    "imported_csv_path",
    "imported_at"
  ],
  "title": "VerificationReviewResolutionArtifact",
  "type": "object"
}