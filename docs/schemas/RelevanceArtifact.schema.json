{
  "$defs": {
    "EvidenceSnippet": {
      "additionalProperties": false,
      "description": "판정 또는 요약 근거로 사용된 snippet.",
      "properties": {
        "locator": {
          "description": "근거 위치 정보",
          "title": "Locator",
          "type": "string"
        },
        "snippet_text": {
          "description": "근거 본문",
          "title": "Snippet Text",
          "type": "string"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "근거의 원문 URL",
          "title": "Source Url"
        },
        "supports_fields": {
          "description": "이 snippet이 뒷받침하는 필드 이름 목록",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Supports Fields",
          "type": "array"
        }
      },
      "required": [
        "locator",
        "snippet_text",
        "supports_fields"
      ],
      "title": "EvidenceSnippet",
      "type": "object"
    },
    "PipelineRun": {
      "additionalProperties": false,
      "description": "주간 배치 실행 단위를 표현하는 모델.",
      "properties": {
        "config_version": {
          "description": "사용된 설정 버전",
          "title": "Config Version",
          "type": "string"
        },
        "domain": {
          "description": "대상 기술 분야",
          "title": "Domain",
          "type": "string"
        },
        "ended_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "실행 종료 시각",
          "title": "Ended At"
        },
        "operator": {
          "description": "실행한 운영자 또는 배치 주체",
          "title": "Operator",
          "type": "string"
        },
        "run_id": {
          "description": "주간 실행 식별자",
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        },
        "stage_status": {
          "additionalProperties": {
            "$ref": "#/$defs/StageExecutionState"
          },
          "description": "stage별 진행 상태",
          "propertyNames": {
            "$ref": "#/$defs/StageName"
          },
          "title": "Stage Status",
          "type": "object"
        },
        "started_at": {
          "description": "실행 시작 시각",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "week_start": {
          "description": "주간 브리프 기준 시작일",
          "format": "date",
          "title": "Week Start",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "domain",
        "week_start",
        "started_at",
        "operator",
        "config_version"
      ],
      "title": "PipelineRun",
      "type": "object"
    },
    "RelevanceAssessment": {
      "additionalProperties": false,
      "description": "관련성 판정 결과와 근거.",
      "properties": {
        "decision_reason": {
          "description": "판정 사유 요약",
          "title": "Decision Reason",
          "type": "string"
        },
        "document_id": {
          "description": "대상 문헌 ID",
          "title": "Document Id",
          "type": "string"
        },
        "evidence_links_or_snippets": {
          "description": "관련성 근거",
          "items": {
            "$ref": "#/$defs/EvidenceSnippet"
          },
          "title": "Evidence Links Or Snippets",
          "type": "array"
        },
        "final_decision": {
          "$ref": "#/$defs/RelevanceDecision",
          "description": "최종 관련성 판정"
        },
        "llm_score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "LLM 점수",
          "title": "Llm Score"
        },
        "matched_classifications": {
          "description": "매칭된 분류 코드",
          "items": {
            "type": "string"
          },
          "title": "Matched Classifications",
          "type": "array"
        },
        "matched_terms": {
          "description": "매칭된 용어",
          "items": {
            "type": "string"
          },
          "title": "Matched Terms",
          "type": "array"
        },
        "metadata_score": {
          "description": "메타데이터 점수",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Metadata Score",
          "type": "number"
        },
        "review_required": {
          "default": false,
          "description": "사람 검수 필요 여부",
          "title": "Review Required",
          "type": "boolean"
        },
        "rule_score": {
          "description": "규칙 기반 점수",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Rule Score",
          "type": "number"
        },
        "schema_version": {
          "default": "0.1.0",
          "description": "적용된 canonical schema 버전",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "rule_score",
        "metadata_score",
        "final_decision",
        "decision_reason"
      ],
      "title": "RelevanceAssessment",
      "type": "object"
    },
    "RelevanceDecision": {
      "description": "관련성 판단 결과.",
      "enum": [
        "relevant",
        "borderline",
        "not_relevant"
      ],
      "title": "RelevanceDecision",
      "type": "string"
    },
    "StageExecutionState": {
      "additionalProperties": false,
      "description": "개별 stage 실행 상태.",
      "properties": {
        "artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "해당 stage 산출물의 대표 경로",
          "title": "Artifact Path"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태 설명 또는 실패 메모",
          "title": "Message"
        },
        "status": {
          "$ref": "#/$defs/StageExecutionStatus",
          "description": "현재 stage의 실행 상태"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "상태가 마지막으로 갱신된 시각",
          "title": "Updated At"
        }
      },
      "required": [
        "status"
      ],
      "title": "StageExecutionState",
      "type": "object"
    },
    "StageExecutionStatus": {
      "description": "stage 실행 상태.",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "skipped"
      ],
      "title": "StageExecutionStatus",
      "type": "string"
    },
    "StageName": {
      "description": "파이프라인 stage 이름.",
      "enum": [
        "ingest",
        "normalize",
        "assess_relevance",
        "verify",
        "summarize",
        "explain",
        "review",
        "render"
      ],
      "title": "StageName",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "assess-relevance 단계 산출물.",
  "properties": {
    "assessments": {
      "description": "문헌별 관련성 판정 결과",
      "items": {
        "$ref": "#/$defs/RelevanceAssessment"
      },
      "title": "Assessments",
      "type": "array"
    },
    "run": {
      "$ref": "#/$defs/PipelineRun",
      "description": "연결된 실행 정보"
    },
    "schema_version": {
      "default": "0.1.0",
      "description": "적용된 canonical schema 버전",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run"
  ],
  "title": "RelevanceArtifact",
  "type": "object"
}